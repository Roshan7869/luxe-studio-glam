# Prevent accidental binary-heavy payloads in package
**/*.png
**/*.jpg
**/*.jpeg
**/*.webp
**/*.gif
**/*.ico
**/*.svgz
**/*.ttf
**/*.otf
**/*.woff
**/*.woff2

# Keep package focused on custom code + required tooling
wp-content/plugins/akismet/
wp-content/themes/twentytwentythree/
wp-content/themes/twentytwentyfour/
wp-content/themes/twentytwentyfive/
