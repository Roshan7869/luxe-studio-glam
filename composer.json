{
    "name": "roshan7869/luxe-studio-glam",
    "description": "GlamLux Enterprise Application Modular Monolith",
    "type": "project",
    "license": "proprietary",
    "require-dev": {
        "phpunit/phpunit": "^11.5|^12.0",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "GlamLux\\": "wp-content/plugins/glamlux-core/",
            "GlamLux\\Test\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyze": "phpstan analyze"
    }
}